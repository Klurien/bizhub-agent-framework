{
  "name": "@biz-hub/mcp-server",
  "version": "1.3.0",
  "description": "Enterprise MCP server for BizHub marketplace — connect AI agents (Claude, Cursor, Copilot) to manage products, orders, inventory, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
